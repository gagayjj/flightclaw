.container { padding: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 20rpx; }
.status-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.status-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.status-dot.online { background: #4caf50; }
.status-text { font-size: 28rpx; font-weight: 500; color: #333; }
.status-desc { font-size: 24rpx; color: #999; padding: 8rpx 0; }
.rule-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.rule-label { font-size: 26rpx; color: #333; }
.rule-value { font-size: 26rpx; color: #1a73e8; }
.route-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 2rpx solid #f5f5f5; }
.route-label { font-size: 26rpx; color: #333; }
.route-status { font-size: 26rpx; color: #4caf50; }
