/**app.wxss**/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.btn-primary {
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  color: #fff;
  border-radius: 500rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
  display: inline-block;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.tag-direct { background: #e8f5e9; color: #2e7d32; }
.tag-transfer { background: #fff3e0; color: #e65100; }
.tag-cheap { background: #ffebee; color: #c62828; }
.tag-source { background: #e3f2fd; color: #1565c0; font-size: 20rpx; }
